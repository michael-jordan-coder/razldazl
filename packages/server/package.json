{
  "name": "@product/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "product-server": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "dev": "tsx watch src/cli.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@product/ai": "workspace:*",
    "@product/ast-engine": "workspace:*",
    "@product/bridge": "workspace:*",
    "@product/protocol": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8",
    "ws": "^8.18.0"
  },
  "license": "MIT"
}
